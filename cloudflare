#!/usr/bin/env bash
# By: TechGenius

PWD=$(pwd)
ar1="$1"
ar2="$2"
ar3="$3"
OS=$(uname -o)
ARCH=$(uname -m)

# Colores
S1="\033[1;31m" S2="\033[1;32m" S3="\033[1;33m"
S4="\033[1;34m" S5="\033[1;35m" S6="\033[1;36m" S7="\033[1;37m"
YELLOW="\033[1;33m"
R0="\033[00m" D0="\033[2m"

# Detectar Termux
if [[ -n "$TERMUX_VERSION" || "$PREFIX" == *"termux"* || "$HOME" == *"com.termux"* ]]; then
  IS_TERMUX=true
  BIN_PATH="$PREFIX/bin"
  LOGFILE="$HOME/cloudflare-log"
else
  IS_TERMUX=false
  BIN_PATH="/usr/local/bin"
  LOGFILE="/tmp/cloudflare-log"
fi

wait_short() { sleep 0.02; }
wait_long()  { sleep 0.1; }

banner() {
  printf "${YELLOW}"
  printf "  ████████╗███████╗ ██████╗██╗  ██╗\n";        wait_short
  printf "  ╚══██╔══╝██╔════╝██╔════╝██║  ██║\n";        wait_short
  printf "     ██║   █████╗  ██║     ███████║\n";        wait_short
  printf "     ██║   ██╔══╝  ██║     ██╔══██║\n";        wait_short
  printf "     ██║   ███████╗╚██████╗██║  ██║\n";        wait_short
  printf "     ╚═╝   ╚══════╝ ╚═════╝╚═╝  ╚═╝\n";       wait_short
  printf "  ██████╗ ███████╗███╗   ██╗██╗██╗   ██╗███████╗\n"; wait_short
  printf "  ██╔════╝██╔════╝████╗  ██║██║██║   ██║██╔════╝\n"; wait_short
  printf "  ██║  ███╗█████╗  ██╔██╗ ██║██║██║   ██║███████╗\n"; wait_short
  printf "  ██║   ██║██╔══╝  ██║╚██╗██║██║██║   ██║╚════██║\n"; wait_short
  printf "  ╚██████╔╝███████╗██║ ╚████║██║╚██████╔╝███████║\n"; wait_short
  printf "   ╚═════╝ ╚══════╝╚═╝  ╚═══╝╚═╝ ╚═════╝ ╚══════╝\n"; wait_short
  printf "${R0}\n"
  printf "${S4}  By: ${S7}TechGenius${R0}\n";             wait_short
  printf "${YELLOW}  [____________TechGenius-Cloudflare____________]${R0}\n\n"; wait_short
}

Animate() {
  printf "${S2}  Generating Link${S5}      ${R0}\r"; wait_long
  printf "${S2}  Generating Link${S5}.     ${R0}\r"; wait_long
  printf "${S2}  Generating Link${S5}..    ${R0}\r"; wait_long
  printf "${S2}  Generating Link${S5}...   ${R0}\r"; wait_long
  printf "${S2}  Generating Link${S5}....  ${R0}\r"; wait_long
  printf "${S2}  Generating Link${S5}..... ${R0}\r"; wait_long
}

HTTP() {
  # Matar instancias previas
  pkill -f cloudflared 2>/dev/null
  sleep 1
  rm -f "$LOGFILE"

  printf "${S4}  Iniciando túnel en puerto ${ar2}...${R0}\n"

  # Lanzar cloudflared — Termux no necesita termux-chroot en versiones modernas
  cloudflared tunnel --url "http://127.0.0.1:${ar2}" --logfile "$LOGFILE" > /dev/null 2>&1 &

  # Esperar y capturar URL con reintentos
  printf "\033[?25l"
  for i in $(seq 1 20); do
    Animate
    forward=$(grep -o 'https://[-a-z0-9]*\.trycloudflare\.com' "$LOGFILE" 2>/dev/null)
    if [[ -n "$forward" ]]; then
      printf "\033[?25h"
      if [[ $1 == '-s' || $1 == '--silent' ]]; then
        printf "%s\n" "$forward"
      else
        printf "\n\n${S2}  [✓] Túnel activo!${R0}\n"
        printf "${S4}  FORWARDING: ${R0}${D0}%s${R0}\n\n" "$forward"
      fi
      return 0
    fi
  done

  printf "\033[?25h"
  printf "\n${S1}  [!] No se pudo obtener la URL.${R0}\n"
  printf "${YELLOW}  Verifica que el puerto ${ar2} esté activo.${R0}\n"
  exit 1
}

check_root() {
  # Termux nunca necesita root
  if $IS_TERMUX; then
    return 0
  fi
  if [[ ${OS^^} == "GNU/LINUX" ]]; then
    if [[ "$EUID" -ne 0 ]]; then
      printf "${S1}  [!] Ejecuta como root: sudo bash cloudflare${R0}\n"
      exit 1
    fi
  fi
}

update() {
  printf "${S2}  Actualizando...${R0}\n"
  if $IS_TERMUX; then
    rm -f "$BIN_PATH/cloudflare" 2>/dev/null
    cp ./cloudflare "$BIN_PATH/cloudflare" 2>/dev/null
    chmod +x "$BIN_PATH/cloudflare"
  else
    sudo rm -f "$BIN_PATH/cloudflare" 2>/dev/null
    sudo cp ./cloudflare "$BIN_PATH/cloudflare" 2>/dev/null
    sudo chmod +x "$BIN_PATH/cloudflare"
  fi
  printf "${S2}  [✓] Actualización completada!${R0}\n"
}

help() {
  echo -e "
  ${YELLOW}TechGenius - Cloudflare Tunnel${R0}

  ${S2}USO:${R0}
    cloudflare http <puerto> [opción]

  ${S2}OPCIONES:${R0}
    -s, --silent    Omitir banner
    -u, --update    Actualizar script
    -h, --help      Mostrar este menú

  ${S2}EJEMPLOS:${R0}
    cloudflare http 8080
    cloudflare http 3000 --silent
  "
}

main() {
  check_root

  if [[ -z "$ar1" ]]; then
    printf "${S1}  [!] Argumento faltante. Usa --help para ver el menú.${R0}\n"
    exit 1
  fi

  case "${ar1,,}" in
    http)
      if [[ -z "$ar2" ]]; then
        printf "${S1}  [!] Indica un puerto. Ejemplo: cloudflare http 8080${R0}\n"
        exit 1
      fi
      if [[ $ar3 == '-s' || $ar3 == '--silent' ]]; then
        HTTP -s
      else
        banner
        HTTP
      fi
      ;;
    -u|--update)
      update
      ;;
    -h|--help)
      help
      ;;
    *)
      printf "${S1}  [!] Argumento inválido. Usa --help para ver el menú.${R0}\n"
      exit 1
      ;;
  esac
}

main