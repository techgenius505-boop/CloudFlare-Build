  printf "${YELLOW}"
  printf "  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•—  в–Ҳв–Ҳв•—\n";        wait_short
  printf "  в•ҡв•җв•җв–Ҳв–Ҳв•”в•җв•җв•қв–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘\n";        wait_short
  printf "     в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘\n";        wait_short
  printf "     в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•”в•җв•җв•қ  в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘\n";        wait_short
  printf "     в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘\n";        wait_short
  printf "     в•ҡв•җв•қ   в•ҡв•җв•җв•җв•җв•җв•җв•қ в•ҡв•җв•җв•җв•җв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қ\n";       wait_short
  printf "  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв•—   в–Ҳв–Ҳв•—в–Ҳв–Ҳв•—в–Ҳв–Ҳв•—   в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—\n"; wait_short
  printf "  в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қ\n"; wait_short
  printf "  в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв•”в–Ҳв–Ҳв•— в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—\n"; wait_short
  printf "  в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•қ  в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в•ҡв•җв•җв•җв•җв–Ҳв–Ҳв•‘\n"; wait_short
  printf "  в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘ в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘\n"; wait_short
  printf "   в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•җв•җв•җв•җв•җв•қв•ҡв•җв•қ  в•ҡв•җв•җв•җв•қв•ҡв•җв•қ в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•җв•җв•җв•җв•җв•қ\n"; wait_short
  printf "${R0}\n"
  printf "${S4}  By: ${S7}TechGenius${R0}\n";             wait_short
  printf "${YELLOW}  [____________TechGenius-Cloudflare____________]${R0}\n\n"; wait_short
}

Animate() {
  printf "${S2}  Generating Link${S5}      ${R0}\r"; wait_long
  printf "${S2}  Generating Link${S5}.     ${R0}\r"; wait_long
  printf "${S2}  Generating Link${S5}..    ${R0}\r"; wait_long
  printf "${S2}  Generating Link${S5}...   ${R0}\r"; wait_long
  printf "${S2}  Generating Link${S5}....  ${R0}\r"; wait_long
  printf "${S2}  Generating Link${S5}..... ${R0}\r"; wait_long
}

check_version() {
  if $IS_TERMUX; then
    local CURRENT
    CURRENT=$(cloudflared --version 2>&1 | grep -o '[0-9]*\.[0-9]*\.[0-9]*' | head -1)

    if [[ "$CURRENT" != "2021.10.3" ]]; then
      printf "${YELLOW}  [!] VersiГіn incorrecta ($CURRENT), corrigiendo...${R0}\n"

      pkg uninstall cloudflared -y > /dev/null 2>&1
      rm -f "$BIN_PATH/cloudflared" 2>/dev/null
      rm -f $HOME/cloudflared 2>/dev/null

      local VERSION="2021.10.3"
      case $ARCH in
        aarch64|armv8)
          URL="https://github.com/cloudflare/cloudflared/releases/download/${VERSION}/cloudflared-linux-arm64" ;;
        armv7l|aarch32)
          URL="https://github.com/cloudflare/cloudflared/releases/download/${VERSION}/cloudflared-linux-arm" ;;
        x86_64|amd64)
          URL="https://github.com/cloudflare/cloudflared/releases/download/${VERSION}/cloudflared-linux-amd64" ;;
        i686|x86)
          URL="https://github.com/cloudflare/cloudflared/releases/download/${VERSION}/cloudflared-linux-386" ;;
        *)
          printf "${S1}  [!] Arquitectura no soportada: $ARCH${R0}\n"; exit 1 ;;
      esac

      cd $HOME
      wget "$URL" -O cloudflared > /dev/null 2>&1
      chmod +x cloudflared
      mv cloudflared "$BIN_PATH/cloudflared"
      chmod 555 "$BIN_PATH/cloudflared"  # вҶҗ evita que se sobreescriba
      printf "${S2}  [вң“] VersiГіn 2021.10.3 instalada correctamente${R0}\n\n"
    else
      chmod 555 "$BIN_PATH/cloudflared"  # вҶҗ asegurar permisos aunque ya estГ©
    fi
  fi
}

HTTP() {
  # Matar instancias previas
  pkill -f cloudflared 2>/dev/null
  pkill -9 -f cloudflared 2>/dev/null
  sleep 2
  rm -f "$LOGFILE"

  printf "${S4}  Iniciando tГәnel en puerto ${ar2}...${R0}\n"

  # Lanzar cloudflared
  if $IS_TERMUX; then
    cloudflared --no-autoupdate -url 127.0.0.1:${ar2} --logfile "$LOGFILE" > /dev/null 2>&1 &
    sleep 2
  else
    cloudflared tunnel --url "http://127.0.0.1:${ar2}" --logfile "$LOGFILE" > /dev/null 2>&1 &
    sleep 3
  fi

  # Esperar y capturar URL
  printf "\033[?25l"
  for i in $(seq 1 20); do
    Animate

    # Formato JSON
    forward=$(grep -o '"url":"https://[-a-z0-9]*\.trycloudflare\.com"' "$LOGFILE" 2>/dev/null | grep -o 'https://[-a-z0-9]*\.trycloudflare\.com')

    # Formato texto plano
    if [[ -z "$forward" ]]; then
      forward=$(grep -o 'https://[-a-z0-9]*\.trycloudflare\.com' "$LOGFILE" 2>/dev/null)
    fi

    if [[ -n "$forward" ]]; then
      printf "\033[?25h"
      if [[ $1 == '-s' || $1 == '--silent' ]]; then
        printf "%s\n" "$forward"
      else
        printf "\n\n${S2}  [вң“] TГәnel activo!${R0}\n"
        printf "${S4}  FORWARDING: ${R0}${D0}%s${R0}\n\n" "$forward"
      fi
      return 0
    fi
  done

  printf "\033[?25h"
  printf "\n${S1}  [!] No se pudo obtener la URL.${R0}\n"
  printf "${YELLOW}  Verifica que el puerto ${ar2} estГ© activo.${R0}\n"
  exit 1
}

check_root() {
  if $IS_TERMUX; then
    return 0
  fi
  if [[ ${OS^^} == "GNU/LINUX" ]]; then
    if [[ "$EUID" -ne 0 ]]; then
      printf "${S1}  [!] Ejecuta como root: sudo cloudflare${R0}\n"
      exit 1
    fi
  fi
}

update() {
  printf "${S2}  Actualizando...${R0}\n"
  if $IS_TERMUX; then
    rm -f "$BIN_PATH/cloudflare" 2>/dev/null
    cp "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/cloudflare" "$BIN_PATH/cloudflare" 2>/dev/null
    chmod +x "$BIN_PATH/cloudflare"
  else
    sudo rm -f "$BIN_PATH/cloudflare" 2>/dev/null
    sudo cp "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/cloudflare" "$BIN_PATH/cloudflare" 2>/dev/null
    sudo chmod +x "$BIN_PATH/cloudflare"
  fi
  printf "${S2}  [вң“] ActualizaciГіn completada!${R0}\n"
}

help() {
  echo -e "
  ${YELLOW}TechGenius - Cloudflare Tunnel${R0}

  ${S2}USO:${R0}
    cloudflare http <puerto> [opciГіn]

  ${S2}OPCIONES:${R0}
    -s, --silent    Omitir banner
    -u, --update    Actualizar script
    -h, --help      Mostrar este menГә

  ${S2}EJEMPLOS:${R0}
    cloudflare http 8080
    cloudflare http 3000 --silent
  "
}

main() {
  check_version
  check_root

  if [[ -z "$ar1" ]]; then
    printf "${S1}  [!] Argumento faltante. Usa --help para ver el menГә.${R0}\n"
    exit 1
  fi

  case "${ar1,,}" in
    http)
      if [[ -z "$ar2" ]]; then
        printf "${S1}  [!] Indica un puerto. Ejemplo: cloudflare http 8080${R0}\n"
        exit 1
      fi
      if [[ $ar3 == '-s' || $ar3 == '--silent' ]]; then
        HTTP -s
      else
        banner
        HTTP
      fi
      ;;
    -u|--update)
      update
      ;;
    -h|--help)
      help
      ;;
    *)
      printf "${S1}  [!] Argumento invГЎlido. Usa --help para ver el menГә.${R0}\n"
      exit 1
      ;;
  esac
}

main