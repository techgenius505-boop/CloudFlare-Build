#!/usr/bin/env bash
# By: TechGenius

PWD=$(pwd)
ar1="$1"
ar2="$2"
ar3="$3"
OS=$(uname -o)
ARCH=$(uname -m)

# Colores
S1="\033[1;31m" S2="\033[1;32m" S3="\033[1;33m"
S4="\033[1;34m" S5="\033[1;35m" S6="\033[1;36m" S7="\033[1;37m"
YELLOW="\033[1;33m"
R0="\033[00m" D0="\033[2m"

# Detectar Termux
if [[ -n "$TERMUX_VERSION" || "$PREFIX" == *"termux"* || "$HOME" == *"com.termux"* ]]; then
  IS_TERMUX=true
  BIN_PATH="$PREFIX/bin"
  LOGFILE="$(pwd)/cloudflare-log"
else
  IS_TERMUX=false
  BIN_PATH="/usr/local/bin"
  LOGFILE="/tmp/cloudflare-log"
fi

# Version requerida para Termux
REQUIRED_VERSION="2021.10.3"

wait_short() { sleep 0.02; }
wait_long()  { sleep 0.1; }

